#!/usr/bin/env bash

set -euo pipefail

BRANCH=$(git branch --show-current)

if [[ "$BRANCH" =~ ^(master|main|branch-.*|develop)$ ]]; then
  RED='\033[0;31m'
  RESET='\033[0m'
  echo -e "\n${RED}Prevented committing and pushing to $BRANCH. Use --no-verify to bypass this hook.${RESET}\n"
  exit 1
fi

exit 0
